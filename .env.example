# ============================================================
# Sismo Voluntarios — Environment Variables
# ============================================================
# Copy this to .env and fill in the values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env files to git.
# Generate secrets with: openssl rand -hex 32
# ============================================================

# Database
SISMO_DB_NAME=sismo
SISMO_DB_USER=db_user
SISMO_DB_PASSWORD=CHANGE_ME_WITH_A_STRONG_PASSWORD

# Puertos (abstractos)
SISMO_API_PORT=8000
SISMO_WEB_PORT=3001
SISMO_PG_PORT=5432

# Google OAuth (required)
# Create at: https://console.cloud.google.com/apis/credentials
SISMO_GOOGLE_CLIENT_ID=your-google-client-id
SISMO_GOOGLE_CLIENT_SECRET=your-google-client-secret
SISMO_GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# Session secret (generate with: openssl rand -hex 32)
# NEVER use "changeme" - this MUST be a random secret
SISMO_SESSION_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32
# Session model: a SHORT-LIVED access token (the signed session cookie) plus a
# revocable, rotating refresh token stored server-side in Redis.
# - SISMO_SESSION_MAX_AGE_SECONDS: access token lifetime (should be short, e.g. 30 min).
# - SISMO_SESSION_REFRESH_MAX_AGE_SECONDS: refresh token lifetime (e.g. 30 days).
# Logging out, or changing a user's role/status, revokes outstanding refresh
# tokens immediately; the access token is then rejected once it lapses.
SISMO_SESSION_MAX_AGE_SECONDS=1800
SISMO_SESSION_REFRESH_MAX_AGE_SECONDS=2592000

# SEP platform integration (optional, server-to-server)
# Two distinct Bearer tokens. The SEP backend presents them in the
# `Authorization: Bearer <token>` header. Provision SEP with DIFFERENT values so
# a leak in one channel cannot be replayed on the other. SISMO se sirve como una
# página más bajo el dominio del SEP (reverse proxy o contenedor); la identidad
# va siempre por sep-login (one-time code con PKCE), no por iframe. Leave both
# unset to disable SEP integration. Generate each with: openssl rand -hex 32
#
# Token para el handshake de login (POST /api/v1/auth/sep-login). Un leak aquí
# permite acuñar sesiones por cualquier sep_user_id; protéjalo como secreto.
SISMO_SEP_LOGIN_TOKEN=
# Token de solo lectura para la Partner API (notificaciones del header del SEP,
# /partner/v1/...). Un leak aquí solo expone datos de notificaciones.
SISMO_SEP_PARTNER_TOKEN=
# DEPRECATED: secreto único anterior que autorizaba ambos canales. Se conserva
# como fallback si no defines los dos anteriores. Mejor definir los dos.
SISMO_SEP_API_TOKEN=

# CORS / Origins (comma-separated for multiple)
SISMO_API_CORS_ORIGINS=http://localhost:3001
SISMO_WEB_ORIGIN=http://localhost:3001

# Rate limiting
# Set to "true" ONLY when the API is deployed behind a trusted proxy that
# overwrites X-Forwarded-For / CF-Connecting-IP (e.g. Cloudflare). When false
# (recommended default) the peer socket address is used, preventing clients
# from spoofing their rate-limit bucket.
SISMO_RATE_LIMIT_TRUST_PROXY=false
SISMO_RATE_LIMIT_PUBLIC_PER_MIN=60
SISMO_RATE_LIMIT_AUTH_PER_MIN=30
SISMO_RATE_LIMIT_BURST=10
# Topos de corto plazo para el autocompletado con IA (dispara una peticion
# por cada pausa de escritura, por eso son mas generosos que el publico).
SISMO_AI_RATE_LIMIT_PER_MIN=600
SISMO_AI_RATE_LIMIT_BURST=200
# Tope por usuario por hora (no es diario). Las llamadas canceladas por el
# cliente se reembolsan y no lo consumen.
SISMO_AI_RATE_LIMIT_PER_USER_PER_HOUR=5000
# Redis shared counter (falls back to in-process counters if unreachable)
SISMO_REDIS_URL=redis://localhost:6379/0

# Frontend (public, exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WEB_ORIGIN=http://localhost:3001
# Ruta base cuando SISMO se sirve bajo un sub-path del dominio del SEP
# (ej. /voluntarios-becarios). Vacío => se sirve en la raíz.
NEXT_PUBLIC_BASE_PATH=

# Cloudflare Tunnel (production only)
# CLOUDFLARE_TUNNEL_TOKEN=your-token
