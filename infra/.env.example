# ============================================================
# Sismo Voluntarios — Infrastructure Environment Variables
# ============================================================
# Used by docker-compose in production.
# Copy to infra/.env and fill in real values.
# ============================================================

# --- Puertos (abstractos, sobrescribibles) ---
SISMO_API_PORT=8000
SISMO_WEB_PORT=3000
SISMO_PG_PORT=5432

# --- Base de datos ---
# Por defecto el override levanta postgres local. Para usar una BD
# EXTERNA: levanta solo la base con
#   docker compose -f docker-compose.yml up -d
# y ajusta aquí el host/puerto:
SISMO_DB_HOST=postgres
SISMO_DB_PORT=5432
SISMO_DB_NAME=sismo
SISMO_DB_USER=db_user
SISMO_DB_PASSWORD=CHANGE_ME_WITH_A_STRONG_PASSWORD

# Redis (externo: levanta solo la base y pon tu URL)
SISMO_REDIS_URL=redis://redis:6379/0

# CORS (comma-separated)
SISMO_API_CORS_ORIGINS=https://sismo.lat,https://www.sismo.lat
SISMO_WEB_ORIGIN=https://sismo.lat

# Public URLs (exposed to browser)
NEXT_PUBLIC_API_URL=https://api.sismo.lat
NEXT_PUBLIC_WEB_ORIGIN=https://sismo.lat

# Cloudflare Tunnel (actívalo con el perfil "tunnel")
CLOUDFLARE_TUNNEL_TOKEN=your-token-here
