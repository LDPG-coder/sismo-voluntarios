# ============================================================
# Sismo Voluntarios — Infrastructure Environment Variables
# ============================================================
# Used by docker-compose in production.
# Copy to infra/.env and fill in real values.
# ============================================================

# --- Puertos (abstractos, sobrescribibles) ---
SISMO_API_PORT=8000
SISMO_WEB_PORT=3000
SISMO_PG_PORT=5432

# --- Base de datos ---
# Por defecto el override levanta postgres local. Para usar una BD
# EXTERNA: levanta solo la base con
#   docker compose -f docker-compose.yml up -d
# y ajusta aquí el host/puerto:
SISMO_DB_HOST=postgres
SISMO_DB_PORT=5432
SISMO_DB_NAME=sismo
SISMO_DB_USER=db_user
SISMO_DB_PASSWORD=CHANGE_ME_WITH_A_STRONG_PASSWORD

# Redis (externo: levanta solo la base y pon tu URL)
SISMO_REDIS_URL=redis://redis:6379/0

# CORS (comma-separated). Para SEP: agrega el origen de SEP (campana de notificaciones).
# Cuando SISMO se sirva bajo el dominio del SEP, incluye ese origen (ej. https://sep.org).
SISMO_API_CORS_ORIGINS=https://sismo.lat,https://www.sismo.lat
SISMO_WEB_ORIGIN=https://sismo.lat

# Public URLs (exposed to browser)
NEXT_PUBLIC_API_URL=https://api.sismo.lat
NEXT_PUBLIC_WEB_ORIGIN=https://sismo.lat
# Ruta base cuando SISMO se sirve como "una página más" bajo el dominio del SEP
# (ej. /voluntarios-becarios). Se hornea en el build del web. Vacío => raíz.
NEXT_PUBLIC_BASE_PATH=
# URL (dentro del stack) del endpoint JSON de navegación del SEP que SISMO
# renderiza en su sidebar. Vacío => sidebar de SEP vacío (fallback). Ver
# docs/SEP_INTEGRATION.md §2.2 (contrato del JSON).
SEP_NAVIGATION_URL=

# Cloudflare Tunnel (actívalo con el perfil "tunnel")
CLOUDFLARE_TUNNEL_TOKEN=your-token-here

# --- Almacenamiento de multimedia (fuera de la BD) ---
# Los archivos (fotos, constancias, adjuntos) se guardan en un volumen del
# servidor y la base de datos solo conserva una referencia. Se sirven vía la
# API autenticada en https://api.sismo.lat/media/{id}. Google Drive queda como
# destino de respaldo en frío, no para servir en caliente.
SISMO_MEDIA_STORAGE_BACKEND=local
SISMO_MEDIA_ROOT=/data/media
SISMO_MEDIA_PUBLIC_BASE_URL=https://api.sismo.lat/media
# Límites (opcionales; estos son los valores por defecto):
# SISMO_MEDIA_MAX_IMAGE_BYTES=5242880
# SISMO_MEDIA_MAX_DOCUMENT_BYTES=8388608

